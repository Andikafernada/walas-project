# n8n Environment Configuration

# Copy this file to .env and fill in your values

# n8n Credentials
N8N_USER=admin
N8N_PASSWORD=changeme123

# n8n URL (public URL for webhooks)
N8N_HOST=your-domain.com
N8N_WEBHOOK_URL=https://your-domain.com

# PostgreSQL Database
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=changeme123

# WaliKelas Pro API
WALAS_API_URL=http://localhost:8000
WALAS_API_KEY=your-walas-api-key

# WhatsApp Gateway (Fonnte)
FONNTE_API_KEY=your-fonnte-api-key
FONNTE_URL=https://mu.fonnte.com/api/send

# WhatsApp Gateway (Wablas)
WABLAS_URL=https://your-wablas-domain.com/send
WABLAS_TOKEN=your-wablas-token
